<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteApp.Pages.AddNotePage"
             Title="Новая заметка">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Entry x:Name="TitleEntry" Placeholder="Заголовок" />
        <Button Text="Сделать фото" Clicked="OnTakePhotoClicked" />
        <Button Text="Выбрать из галереи" Clicked="OnPickPhotoClicked" />
        <Image x:Name="NoteImage" HeightRequest="200" />
        <Button Text="Сохранить" Clicked="OnSaveClicked" />
    </VerticalStackLayout>
</ContentPage>