<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteApp.Pages.MainPage"
             Title="Мои заметки">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Button Text="Добавить заметку" Clicked="OnAddClicked" />
        <CollectionView x:Name="NotesCollectionView" SelectionMode="Single" SelectionChanged="OnNoteSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="10" Padding="10">
                        <Image Source="{Binding PhotoPath}" WidthRequest="50" HeightRequest="50" />
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding CreatedAt}" FontSize="10" />
                        </VerticalStackLayout>
                        <Button Text="Карта" Clicked="OnMapClicked" CommandParameter="{Binding .}" />
                        <Button Text="Удалить" Clicked="OnDeleteNoteClicked" CommandParameter="{Binding .}" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>